# Copy this file to ".env" (or set these as real environment variables) and
# fill in your own values. The .env file is gitignored and never committed.

# --- Standard OpenAI-compatible LLM (default endpoint api.openai.com / Ollama) ---
# Used by record_and_transcribe_vClean.py --llm-finalize
OPENAI_API_KEY=your_api_key_here

# --- Hosted LLM variant (vClean_hostedLLM.py) ---
# These override the built-in defaults of the hosted-LLM helper scripts.
DIZ_AI_KEY=your_hosted_llm_api_key_here
DIZ_AI_BASE=https://your-hosted-llm-endpoint/api
DIZ_AI_MODEL=your-model-name
